# Dockerfile.n8n
# Extends the official n8n image with kubectl for Kubernetes cluster operations.
# kubectl is pinned to a stable version so builds are reproducible.

FROM n8nio/n8n:1.123.55

# Switch to root to install system packages
USER root

# Install kubectl (pinned to v1.30.2 for reproducibility)
ARG KUBECTL_VERSION=v1.30.2
RUN wget "https://dl.k8s.io/release/${KUBECTL_VERSION}/bin/linux/amd64/kubectl" -O /usr/local/bin/kubectl \
    && chmod +x /usr/local/bin/kubectl \
    && kubectl version --client

# Switch back to the non-root n8n user (required for security)
USER node

# Confirm kubectl is accessible as the node user
RUN kubectl version --client
